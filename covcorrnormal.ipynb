   "source": [
    "import pandas as pd\n",
    "\n",
    "data = {\n",
    "    'X': [10, 20, 30, 40, 50],\n",
    "    'Y': [15, 25, 35, 45, 55]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "print(\"Dataset:\")\n",
    "print(df)\n",
    "\n",
    "print(\"\\nVariance:\")\n",
    "print(df.var())\n",
    "\n",
    "print(\"\\nCovariance:\")\n",
    "print(df.cov())\n",
    "\n",
    "print(\"\\nCorrelation:\")\n",
    "print(df.corr())"
   ]
