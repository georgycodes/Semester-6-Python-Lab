   "source": [
    "a=int(input(\"Enter the number:\"))\n",
    "for i in range(a):\n",
    "    print(' '*(a-i),end=' ')\n",
    "    num=1\n",
    "    for j in range(i+1):\n",
    "        print(num,end=' ')\n",
    "        num=num*(i-j)//(j+1)\n",
    "    print()    "
   ]
